PYTHON = .venv/bin/python3.14

# ── Setup ─────────────────────────────────────────────────────────────────────

setup:
	python3 -m venv .venv
	$(PYTHON) -m pip install -r requirements.txt

# ── Run ───────────────────────────────────────────────────────────────────────

run:
	$(PYTHON) personal_assistant.py
